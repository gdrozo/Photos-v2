{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photos",
  "version": "0.1.0",
  "identifier": "com.usuario.photos",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Photos",
        "label": "main",
        "width": 1000,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "color": "#1f1f1f"
        },
        "url": "index.html",
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["C:/**/*", "D:/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "description": "Image file",
        "ext": ["jpg", "jpeg", "png", "gif", "bmp", "tiff", "webp"],
        "name": "Image File",
        "role": "Viewer"
      },
      {
        "description": "Video file",
        "ext": ["mp4", "mkv", "avi", "mov", "wmv", "flv", "webm", "m4v"],
        "name": "Video File",
        "role": "Viewer"
      }
    ]
  }
}
